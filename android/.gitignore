# The Gradle wrapper is tracked: CI runs ./gradlew directly and validates its
# checksum, rather than relying on `flutter build --config-only` to inject it.
/.gradle
/captures/
/local.properties
GeneratedPluginRegistrant.java
.cxx/

# Remember to never publicly share your keystore.
# See https://flutter.dev/to/reference-keystore
key.properties
**/*.keystore
**/*.jks
# The base64 of a keystore is the keystore. `**/*.jks` does not match it.
**/*.jks.base64

# fastlane run artifacts. Metadata and store graphics under fastlane/metadata/
# are tracked on purpose — these are per-run output.
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
