# Copy to .env and fill in. .env is gitignored and CI asserts it stays untracked.
#
#   cp .env.example .env
#
# Nothing here is read automatically — .env is for your shell. Load it before
# running fastlane locally:
#
#   set -a && source .env && set +a
#   cd android && bundle exec fastlane validate
#
# Quote any value containing a space. `source` parses this file as shell, so a
# bare path like /Users/me/Nex NeoTech/... is read as an assignment followed by
# a command, and the variable silently ends up empty.
#
# GitHub Actions does not use this file. It reads repository secrets; the
# mapping from these variables to secret names is in docs/publishing.md.

# ─── npm (backend SDK packages) ──────────────────────────────────────────────
# Only needed to publish @luno-oss/* by hand. CI publishes via OIDC trusted
# publishing and stores no token at all.
NPM_ACCESS_TOKEN=

# ─── Google Play service account ─────────────────────────────────────────────
# Absolute path to the JSON key for the service account that has "Release
# manager" access in Play Console. fastlane's supply reads SUPPLY_JSON_KEY
# directly, so the name must be exactly this.
#
# Create it: Play Console → Setup → API access → link a Google Cloud project →
# create a service account → grant it Play Console access → download a JSON key.
# Keep the file outside the repo.
SUPPLY_JSON_KEY="/absolute/path/to/play-service-account.json"

# ─── Android upload signing ──────────────────────────────────────────────────
# Prefer android/key.properties, which tool/generate_upload_keystore.sh writes
# for you — Gradle picks it up with no environment at all. These four exist for
# CI, and override nothing when key.properties is present.
LUNO_KEYSTORE_PATH=""
LUNO_KEYSTORE_PASSWORD=
LUNO_KEY_ALIAS=upload
LUNO_KEY_PASSWORD=

# ─── Optional ────────────────────────────────────────────────────────────────
# Pins the versionCode instead of deriving it from the highest one Play has
# seen. Leave empty unless you are reproducing a specific build — a value Play
# has already accepted will be rejected.
LUNO_BUILD_NUMBER=
