{
  "name": "@luno/express",
  "version": "0.1.0",
  "description": "Express adapter for @luno/core — enroll routes + a ws-based node socket on a classic Node server",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "peerDependencies": {
    "@luno/core": "workspace:*",
    "express": "^4.18.0 || ^5.0.0"
  },
  "dependencies": {
    "@luno/protocol": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@luno/core": "workspace:*",
    "@luno/testing": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "express": "^4.21.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
