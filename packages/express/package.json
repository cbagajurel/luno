{
  "name": "@luno-oss/express",
  "version": "0.1.0",
  "description": "Express adapter for @luno-oss/core — enroll routes + a ws-based node socket on a classic Node server",
  "license": "Apache-2.0",
  "author": "Shivahari Gajurel",
  "homepage": "https://github.com/cbagajurel/luno/tree/master/packages/express#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbagajurel/luno.git",
    "directory": "packages/express"
  },
  "bugs": {
    "url": "https://github.com/cbagajurel/luno/issues"
  },
  "keywords": [
    "luno",
    "sms",
    "sms-gateway",
    "android",
    "self-hosted",
    "express",
    "adapter",
    "middleware"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "peerDependencies": {
    "@luno-oss/core": "workspace:^",
    "express": "^4.18.0 || ^5.0.0"
  },
  "dependencies": {
    "@luno-oss/protocol": "workspace:^",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@luno-oss/core": "workspace:*",
    "@luno-oss/testing": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "express": "^4.21.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
