{
  "name": "@luno-oss/hono",
  "version": "0.1.0",
  "description": "Hono adapter for @luno-oss/core — fetch-native enroll + WebSocket routes that run on Node, Workers, Deno and Bun",
  "license": "Apache-2.0",
  "author": "Shivahari Gajurel",
  "homepage": "https://github.com/cbagajurel/luno/tree/master/packages/hono#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbagajurel/luno.git",
    "directory": "packages/hono"
  },
  "bugs": {
    "url": "https://github.com/cbagajurel/luno/issues"
  },
  "keywords": [
    "luno",
    "sms",
    "sms-gateway",
    "android",
    "self-hosted",
    "hono",
    "adapter",
    "workers",
    "deno",
    "bun"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "peerDependencies": {
    "@luno-oss/core": "workspace:^",
    "hono": "^4.6.0"
  },
  "dependencies": {
    "@luno-oss/protocol": "workspace:^"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.0.4",
    "@luno-oss/core": "workspace:*",
    "@luno-oss/store-postgres": "workspace:*",
    "@luno-oss/testing": "workspace:*",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "hono": "^4.6.14",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "ws": "^8.18.0"
  }
}
