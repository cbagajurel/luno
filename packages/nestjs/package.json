{
  "name": "@luno-oss/nestjs",
  "version": "0.1.0",
  "description": "NestJS module for @luno-oss/core — a LunoModule (forRoot/forRootAsync) + enroll controller + node socket",
  "license": "Apache-2.0",
  "author": "Shivahari Gajurel",
  "homepage": "https://github.com/cbagajurel/luno/tree/master/packages/nestjs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbagajurel/luno.git",
    "directory": "packages/nestjs"
  },
  "bugs": {
    "url": "https://github.com/cbagajurel/luno/issues"
  },
  "keywords": [
    "luno",
    "sms",
    "sms-gateway",
    "android",
    "self-hosted",
    "nestjs",
    "module",
    "adapter",
    "di"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "peerDependencies": {
    "@luno-oss/core": "workspace:^",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "dependencies": {
    "@luno-oss/protocol": "workspace:^",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@luno-oss/core": "workspace:*",
    "@luno-oss/testing": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "ws": "^8.18.0"
  }
}
