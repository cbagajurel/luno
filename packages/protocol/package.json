{
  "name": "@luno-oss/protocol",
  "version": "0.1.0",
  "description": "Zero-dependency types and codecs for the Luno wire protocol",
  "license": "Apache-2.0",
  "author": "Shivahari Gajurel",
  "homepage": "https://github.com/cbagajurel/luno/tree/master/packages/protocol#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbagajurel/luno.git",
    "directory": "packages/protocol"
  },
  "bugs": {
    "url": "https://github.com/cbagajurel/luno/issues"
  },
  "keywords": [
    "luno",
    "sms",
    "sms-gateway",
    "android",
    "self-hosted",
    "protocol",
    "codec",
    "types",
    "zero-dependency"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fixtures": "./fixtures/frames.json"
  },
  "files": [
    "dist",
    "fixtures"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
