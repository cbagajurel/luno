{
  "name": "@luno-oss/fastify",
  "version": "0.1.0",
  "description": "Fastify plugin for @luno-oss/core — enroll routes + a @fastify/websocket node socket",
  "license": "Apache-2.0",
  "author": "Shivahari Gajurel",
  "homepage": "https://github.com/cbagajurel/luno/tree/master/packages/fastify#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbagajurel/luno.git",
    "directory": "packages/fastify"
  },
  "bugs": {
    "url": "https://github.com/cbagajurel/luno/issues"
  },
  "keywords": [
    "luno",
    "sms",
    "sms-gateway",
    "android",
    "self-hosted",
    "fastify",
    "plugin",
    "adapter"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "peerDependencies": {
    "@fastify/websocket": "^11.0.0",
    "@luno-oss/core": "workspace:^",
    "fastify": "^5.0.0"
  },
  "dependencies": {
    "@luno-oss/protocol": "workspace:^"
  },
  "devDependencies": {
    "@fastify/websocket": "^11.0.2",
    "@luno-oss/core": "workspace:*",
    "@luno-oss/testing": "workspace:*",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "fastify": "^5.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "ws": "^8.18.0"
  }
}
